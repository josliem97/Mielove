xec?",answer:"Cinelove l\xe0 nền tảng tạo thiệp cưới online miễn ph\xed h\xe0ng đầu Việt Nam. Bạn c\xf3 thể tạo thiệp cưới điện tử đẹp mắt, hiện đại chỉ trong v\xe0i ph\xfat với h\xe0ng trăm mẫu thiết kế đa dạng v\xe0 c\xf4ng cụ t\xf9y chỉnh dễ sử dụng."},{question:"T\xf4i phải trả bao nhiều tiền để tạo thiệp cưới?",answer:"Cinelove c\xf3 g\xf3i miễn ph\xed với đầy đủ t\xednh năng để tạo thiệp cưới đẹp v\xe0 chuy\xean nghiệp. Bạn c\xf3 thể tạo, t\xf9y chỉnh v\xe0 chia sẻ thiệp cưới ho\xe0n to\xe0n miễn ph\xed. Ngo\xe0i ra, ch\xfang t\xf4i cũng c\xf3 c\xe1c g\xf3i trả ph\xed với những t\xednh năng n\xe2ng cao để đ\xe1p ứng nhu cầu đa dạng của người d\xf9ng."},{question:"L\xe0m thế n\xe0o để t\xf9y chỉnh thiệp?",answer:"Rất đơn giản! Chọn mẫu thiệp y\xeau th\xedch, sau đ\xf3 thay đổi văn bản, h\xecnh ảnh, m\xe0u sắc, font chữ theo \xfd muốn. Bạn c\xf3 thể th\xeam th\xf4ng tin cặp đ\xf4i, thời gian địa điểm đ\xe1m cưới, lời mời c\xe1 nh\xe2n h\xf3a v\xe0 nhiều yếu tố kh\xe1c chỉ bằng v\xe0i c\xfa nhấp chuột."},{question:"T\xf4i c\xf3 thể chia sẻ thiệp như thế n\xe0o?",answer:"Sau khi ho\xe0n th\xe0nh thiệp, bạn sẽ nhận được link chia sẻ. Bạn c\xf3 thể gửi link n\xe0y qua Messenger, Zalo, hoặc tin nhắn SMS... hoặc chia sẻ trực tiếp l\xean Facebook, Instagram, TikTok... Kh\xe1ch mời chỉ cần nhấp v\xe0o link để xem thiệp ngay tr\xean điện thoại hoặc m\xe1y t\xednh của họ."},{question:"Thiệp c\xf3 hoạt động tr\xean mọi thiết bị kh\xf4ng?",answer:"C\xf3! Thiệp cưới của Cinelove được thiết kế responsive, tự động tối ưu hiển thị tr\xean mọi k\xedch thước m\xe0n h\xecnh từ điện thoại đến m\xe1y t\xednh. Kh\xe1ch mời của bạn c\xf3 thể xem thiệp mượt m\xe0 tr\xean bất kỳ thiết bị n\xe0o."},{question:"Kh\xe1ch mời c\xf3 thể tặng qu\xe0 trực tiếp tr\xean thiệp kh\xf4ng?",answer:"C\xf3! Cinelove c\xf3 2 c\xe1ch tặng qu\xe0 độc đ\xe1o:\n• Qu\xe9t m\xe3 QR để chuyển khoản trực tiếp cho chủ thiệp\n• Tặng c\xe1c m\xf3n qu\xe0 đ\xe1ng y\xeau với hiệu ứng animation đẹp mắt hiển thị ngay tr\xean thiệp\n\nC\xe1c m\xf3n qu\xe0 ảo n\xe0y c\xf3 thể được quy đổi th\xe0nh tiền thật v\xe0 r\xfat về t\xe0i khoản ng\xe2n h\xe0ng theo ch\xednh s\xe1ch qu\xe0 tặng của Cinelove. Bạn c\xf3 thể theo d\xf5i được tất cả qu\xe0 tặng, lời ch\xfac v\xe0 c\xf3 thể quản l\xfd thu nhập một c\xe1ch minh bạch."}];let k=function(){var e=(0,l.useState)([]),t=e[0],n=e[1],i=(0,l.useCallback)(function(e){n(function(t){return t.includes(e)?t.filter(function(t){return t!==e}):[].concat((0,b.A)(t),[e])})},[]),a=(0,l.useMemo)(function(){return{"@context":"https://schema.org","@type":"FAQPage",mainEntity:y.map(function(e){return{"@type":"Question",name:e.question,acceptedAnswer:{"@type":"Answer",text:e.answer}}})}},[]);return(0,h.jsxs)(h.Fragment,{children:[(0,h.jsx)("script",{type:"application/ld+json",dangerouslySetInnerHTML:{__html:JSON.stringify(a)}}),(0,h.jsxs)("div",{className:"jsx-262734203 faq-container",children:[(0,h.jsx)("h2",{className:"jsx-262734203 faq-title",children:"C\xe2u hỏi thường gặp"}),(0,h.jsx)("div",{className:"jsx-262734203 faq-list",children:y.map(function(e,n){var a=t.includes(n);return(0,h.jsxs)("div",{className:"jsx-262734203 faq-item",children:[(0,h.jsxs)("button",{onClick:function(){return i(n)},"aria-expanded":a,"aria-controls":"faq-answer-".concat(n),className:"jsx-262734203 faq-button",children:[(0,h.jsx)("span",{className:"jsx-262734203 faq-question",children:e.question}),(0,h.jsx)("div",{className:"jsx-262734203 faq-icon",children:a?(0,h.jsx)(j.A,{}):(0,h.jsx)(v.A,{})})]}),(0,h.jsx)("div",{id:"faq-answer-".concat(n),className:"jsx-262734203 "+"faq-answer ".concat(a?"faq-answer-open":""),children:(0,h.jsx)("div",{className:"jsx-262734203 faq-answer-content",children:(0,h.jsx)("div",{className:"jsx-262734203 faq-answer-text",children:e.answer})})})]},n)})}),(0,h.jsxs)("div",{className:"jsx-262734203 faq-footer",children:[(0,h.jsx)("p",{className:"jsx-262734203 faq-footer-text",children:"Bạn cần hỗ trợ th\xeam? H\xe3y li\xean hệ với ch\xfang t\xf4i!"