letter",HAPPY_BIRTHDAY:"happy-birthday"},s=[{id:i.CRUSH_KILLER,title:"Crush Killer",description:"Tr\xf2 chơi troll vui nhộn với c\xe2u hỏi 'Cậu c\xf3 y\xeau tớ kh\xf4ng?' v\xe0 n\xfat bấm trốn tr\xe1nh",longDescription:"Crush Killer l\xe0 tr\xf2 chơi troll cực kỳ vui nhộn để 'tr\xeau' crush hoặc bạn b\xe8. Khi họ cố gắng bấm 'Kh\xf4ng', n\xfat sẽ li\xean tục trốn tr\xe1nh một c\xe1ch h\xe0i hước. Bạn c\xf3 thể t\xf9y chỉnh to\xe0n bộ c\xe2u hỏi, lời nhắn v\xe0 h\xecnh ảnh theo \xfd muốn. K\xe8m theo \xe2m thanh vui nhộn v\xe0 nhiều t\xecnh huống bất ngờ, đ\xe2y l\xe0 c\xe1ch ho\xe0n hảo để tạo ra những khoảnh khắc đ\xe1ng nhớ v\xe0 vui vẻ.",keyPassword:"Cinelove_001",thumbnail:"".concat(r.A.CDN_URL,"/custom-web/thumbnails/crush-killer.webp"),gallery:["".concat(r.A.CDN_URL,"/custom-web/thumbnails/crush-killer.webp"),"".concat(r.A.CDN_URL,"/custom-web/thumbnails/crush-killer-1.webp"),"".concat(r.A.CDN_URL,"/custom-web/thumbnails/crush-killer-2.webp")],category:"funny",tags:["tr\xf2 chơi troll","vui nhộn","crush","t\xf9y chỉnh","chia sẻ"],features:["Tr\xf2 chơi troll với n\xfat bấm trốn tr\xe1nh","T\xf9y chỉnh to\xe0n bộ c\xe2u hỏi v\xe0 lời nhắn","Thay đổi h\xecnh ảnh theo sở th\xedch","\xc2m thanh vui nhộn k\xe8m theo","Popup đẹp mắt với nhiều t\xf9y chọn","Hoạt động tốt tr\xean điện thoại","Chia sẻ link cho bạn b\xe8 dễ d\xe0ng","Thiết lập nhanh ch\xf3ng trong v\xe0i ph\xfat"],demoUrl:"/web/crush-killer",isFeatured:!0,isNew:!1,difficulty:"Rất dễ",estimatedTime:"1-3 ph\xfat",techStack:[]},{id:i.APOLOGY_LETTER,title:"Thư Xin Lỗi Đ\xe1ng Y\xeau",description:"Website thư xin lỗi tương t\xe1c đ\xe1ng y\xeau với kawaii style v\xe0 hiệu ứng l\xe3ng mạn",longDescription:"Thư Xin Lỗi Đ\xe1ng Y\xeau l\xe0 website tương t\xe1c si\xeau cute để gửi lời xin lỗi ch\xe2n th\xe0nh đến người y\xeau. Với phong c\xe1ch kawaii đ\xe1ng y\xeau, hiệu ứng sparkle lấp l\xe1nh v\xe0 c\xe1c c\xe2u hỏi tương t\xe1c dễ thương. Website sẽ dẫn dắt người xem qua h\xe0nh tr\xecnh từ c\xe2u hỏi 'Em c\xf3 y\xeau anh kh\xf4ng?' đến l\xe1 thư xin lỗi ch\xe2n th\xe0nh cuối c\xf9ng. Bạn c\xf3 thể t\xf9y chỉnh to\xe0n bộ văn bản, h\xecnh ảnh v\xe0 lời nhắn theo t\xecnh huống ri\xeang của m\xecnh.",thumbnail:"".concat(r.A.CDN_URL,"/custom-web/thumbnails/apology-letter.webp"),gallery:["".concat(r.A.CDN_URL,"/custom-web/thumbnails/apology-letter.webp"),"".concat(r.A.CDN_URL,"/custom-web/thumbnails/apology-letter-2.webp"),"".concat(r.A.CDN_URL,"/custom-web/thumbnails/apology-letter-3.webp")],category:"love",tags:["xin lỗi","thư t\xecnh","kawaii","đ\xe1ng y\xeau","tương t\xe1c","l\xe3ng mạn"],features:["Thiết kế kawaii style cực kỳ đ\xe1ng y\xeau","Hiệu ứng sparkle v\xe0 confetti l\xe3ng mạn","Tương t\xe1c c\xe2u hỏi v\xe0 trả lời vui nhộn","T\xf9y chỉnh to\xe0n bộ văn bản v\xe0 lời nhắn","Thay đổi h\xecnh ảnh theo sở th\xedch","L\xe1 thư xin lỗi ch\xe2n th\xe0nh v\xe0 cảm động","Ph\xf9 hợp cho mọi dịp xin lỗi người y\xeau","Responsive ho\xe0n hảo tr\xean mobile"],demoUrl:"/web/apology-letter",isNew:!0,isFeatured:!0,difficulty:"Dễ sử dụng",estimatedTime:"2-4 ph\xfat",techStack:[]},{id:i.HAPPY_BIRTHDAY,title:"Happy Birthday",description:"Website sinh nhật tương t\xe1c với b\xe1nh sinh nhật, thổi nến online v\xe0 confetti",longDescription:"Happy Birthday l\xe0 website sinh nhật tương t\xe1c cực kỳ th\xfa vị v\xe0 l\xe3ng mạn. Người d\xf9ng c\xf3 thể click để th\xeam nến v\xe0o b\xe1nh sinh nhật, sau đ\xf3 thổi nến online để tắt nến. Khi tất cả nến được thổi tắt, website sẽ b\xf9ng nổ với hiệu ứng confetti tuyệt đẹp, nhạc sinh nhật vui tươi v\xe0 tin nhắn ch\xfac mừng với hiệu ứng typing. Bạn c\xf3 thể t\xf9y chỉnh lời ch\xfac sinh nhật, thay đổi h\xecnh ảnh v\xe0 nhạc nền theo \xfd muốn. Đ\xe2y l\xe0 c\xe1ch ho\xe0n hảo để tạo n\xean một bữa tiệc sinh nhật ảo đầy bất ngờ v\xe0 cảm x\xfac.",thumbnail:"".concat(r.A.CDN_URL,"/custom-web/thumbnails/happy-birthday.webp"),gallery:["".concat(r.A.CDN_URL,"/custom-web/thumbnails/happy-birthday.webp"),"".concat(r.A.CDN_URL,"/custom-w